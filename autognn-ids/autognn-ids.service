[Unit]
Description=AutoGNN-IDS - GNN-Based Network Intrusion Detection System
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root

#edit the location if the WorkingDirectory is different than below
WorkingDirectory=/root/Autognn-ids/autognn-ids
Environment="PATH=/root/Autognn-ids/autognn-ids/.venv/bin:/usr/local/bin:/usr/bin:/bin"
Environment="AUTOGNN_USE_SAMPLE=false"
ExecStart=/opt/autognn-ids/.venv/bin/python -m uvicorn api.fastapi_server:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=autognn-ids

# Security hardening
NoNewPrivileges=false
ProtectSystem=false
ReadOnlyDirectories=/proc/net

[Install]
WantedBy=multi-user.target
ProtectSystem=false
ProtectHome=false
ReadOnlyDirectories=/proc/net

[Install]
WantedBy=multi-user.target
